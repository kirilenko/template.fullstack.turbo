# Docker / CI
BRANCH=main
DOCKER_REGISTRY=ghcr.io
DOCKER_USER=
PROJECT_NAME=
TAG=latest

# App
APP_NAME=App

# Database
POSTGRES_DB=app
POSTGRES_USER=app
POSTGRES_PASSWORD=

# URLs
PUBLIC_API_URL=https://api.yourdomain.com
PUBLIC_APP_URL=https://yourdomain.com,https://control.yourdomain.com

# Auth
BETTER_AUTH_SECRET=
ADMIN_EMAILS=

# Cookie (cross-subdomain)
COOKIE_DOMAIN=.yourdomain.com
COOKIE_PREFIX=app

# SMTP
SMTP_FROM=App <noreply@yourdomain.com>
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=

# S3 Backups
S3_ENDPOINT=
S3_BUCKET=
S3_PREFIX=app/production
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
