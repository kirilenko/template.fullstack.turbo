# Docker / CI
BRANCH=stage
DOCKER_REGISTRY=ghcr.io
DOCKER_USER=
PROJECT_NAME=
TAG=latest

# App
APP_NAME=App (stage)

# Database
POSTGRES_DB=app_stage
POSTGRES_USER=app_stage
POSTGRES_PASSWORD=

# URLs
PUBLIC_API_URL=https://api.stage.yourdomain.com
PUBLIC_APP_URL=https://stage.yourdomain.com,https://control.stage.yourdomain.com

# Auth
BETTER_AUTH_SECRET=
ADMIN_EMAILS=

# Cookie (cross-subdomain)
COOKIE_DOMAIN=.yourdomain.com
COOKIE_PREFIX=app-stage

# SMTP
SMTP_FROM=App (stage) <noreply@yourdomain.com>
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
