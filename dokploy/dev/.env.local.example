# Docker / CI
BRANCH=dev
DOCKER_REGISTRY=ghcr.io
DOCKER_USER=
PROJECT_NAME=
TAG=latest

# App
APP_NAME=App (dev)

# Database
POSTGRES_DB=app_dev
POSTGRES_USER=app_dev
POSTGRES_PASSWORD=

# URLs
PUBLIC_API_URL=https://api.dev.yourdomain.com
PUBLIC_APP_URL=https://dev.yourdomain.com,https://control.dev.yourdomain.com

# Auth
BETTER_AUTH_SECRET=
ADMIN_EMAILS=

# Cookie (cross-subdomain)
COOKIE_DOMAIN=.yourdomain.com
COOKIE_PREFIX=app-dev

# SMTP
SMTP_FROM=App (dev) <noreply@yourdomain.com>
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
