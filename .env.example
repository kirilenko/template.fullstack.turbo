# === App ===
APP_NAME=App

# === API Ports (auto-generated by scripts/sync-ports.sh from ports.yml) ===
# These are written to .env.ports.local — do not set manually.
# See "Ports" section in CLAUDE.md for setup instructions.
PORT=3001
PORT_VITE_CONTROL=5184
PORT_ASTRO_PUBLIC=5185
PORT_POSTGRES=5438
PORT_REDIS=6381

# === URLs ===
PUBLIC_API_URL=http://localhost:3001
PUBLIC_APP_URL=http://localhost:5181,http://localhost:5182

# === Database ===
DATABASE_URL=postgresql://app:app@localhost:5432/app

# === Redis ===
REDIS_URL=redis://localhost:6379

# === Better-Auth ===
BETTER_AUTH_SECRET=                    # generate: openssl rand -base64 32

# === Auth settings ===
ADMIN_EMAILS=                          # comma-separated list of admin emails

# === Cookie settings (for cross-subdomain auth in production) ===
COOKIE_DOMAIN=                         # e.g. .yourdomain.com
COOKIE_PREFIX=better-auth              # e.g. myapp

# === SMTP (optional — logs to console if not set) ===
SMTP_FROM=                             # e.g. App <noreply@yourdomain.com>
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=

# === Site URL (for Astro sitemap) ===
SITE_URL=https://yourdomain.com

# === Timestamp (injected at build time) ===
PUBLIC_TIMESTAMP=
