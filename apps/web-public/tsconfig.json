{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "skipLibCheck": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "erasableSyntaxOnly": true,
    "paths": {
      "@/*": ["./src/*"],
      "@apps/service-api/*": ["../service-api/*"],
      "@packages/api-client": ["../../packages/api-client/src/index.ts"],
      "@packages/lib/*": ["../../packages/lib/src/*/index.ts"],
      "@packages/ui": ["../../packages/ui/src/index.ts"]
    },
    "types": ["vite/client"]
  },
  "include": ["src"]
}
